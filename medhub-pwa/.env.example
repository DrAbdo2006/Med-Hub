# Copy this file to `.env` and fill in real values from your Supabase project.
# `.env` is gitignored; `.env.example` is committed so collaborators know the shape.
#
# Project Settings → API:
#   "Project URL"  -> VITE_SUPABASE_URL
#   "anon public" key OR a "publishable" key (sb_publishable_...) -> VITE_SUPABASE_ANON_KEY
# Do NOT use the service_role / secret key in the frontend.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY
